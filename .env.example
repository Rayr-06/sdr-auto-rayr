# ═══════════════════════════════════════════════════════════
#  SDR Autopilot — Environment Configuration
# ═══════════════════════════════════════════════════════════

# ── Database (required) ─────────────────────────────────────
# FREE Postgres from Neon: https://neon.tech (takes 2 minutes)
# After creating DB, Neon gives you two URLs - use both:
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# For LOCAL development only (SQLite still works locally):
# DATABASE_URL=file:./db/sdr.db

# ── AI Provider ─────────────────────────────────────────────
# GROQ - FREE: https://console.groq.com (30 seconds to get key)
GROQ_API_KEY=

# Anthropic Claude (best quality)
ANTHROPIC_API_KEY=

# ── Security ────────────────────────────────────────────────
ADMIN_SECRET=change-this-to-random-string

# ── Email Sending (optional) ─────────────────────────────────
# Free 100 emails/day: https://sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=you@yourdomain.com
SENDGRID_FROM_NAME=SDR Autopilot

# ── App ──────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1

# ── ZoomInfo (Real Prospects + Intent Data) ──────────────────
# Get from: https://api.zoominfo.com
ZOOMINFO_CLIENT_ID=
ZOOMINFO_CLIENT_SECRET=

# ── ZoomInfo Engage (Real Email Sending + Tracking) ──────────
# Get from: Engage Settings > API
ENGAGE_API_KEY=
ENGAGE_MAILBOX_EMAIL=you@yourcompany.com

# ── SendGrid (Alternative email sending) ─────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=you@yourcompany.com
SENDGRID_FROM_NAME=SDR Autopilot
