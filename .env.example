# ═══════════════════════════════════════════════════════════════
#  SDR Autopilot — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Database (required) ─────────────────────────────────────────
# SQLite for local dev — zero setup needed
DATABASE_URL=file:./db/sdr.db
# For production (Vercel / Railway), use Postgres:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── AI Provider — pick ONE ───────────────────────────────────────
# Priority: GROQ → ANTHROPIC → OPENAI → demo mode

# OPTION 1: Groq (FREE & fast — recommended for testing)
# Get key in 30 seconds at https://console.groq.com
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OPTION 2: Anthropic Claude (best quality)
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OPTION 3: OpenAI or any compatible API
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# ── Email Sending (optional) ─────────────────────────────────────
# Without this, emails are simulated (demo mode)
# Get 100 free emails/day at https://sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=you@yourdomain.com
SENDGRID_FROM_NAME=SDR Autopilot

# ── Security ─────────────────────────────────────────────────────
# Protects the /api/admin/reset endpoint
# Generate: openssl rand -hex 32
ADMIN_SECRET=change-this-to-a-random-secret

# ── App ──────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
